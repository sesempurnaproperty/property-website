<!DOCTYPE html>
<html>
<head>
<title>Sesempurna Property</title>

<style>

body{
font-family:Arial;
margin:0;
background:#f4f4f4;
}

/* HEADER */

header{
background:#1e88e5;
color:white;
padding:20px;
text-align:center;
}

/* HOT PROPERTY */

.hot-section{
padding:40px;
background:white;
text-align:center;
}

.hot-title{
font-size:28px;
margin-bottom:30px;
}

.hot-container{
display:flex;
gap:20px;
justify-content:center;
flex-wrap:wrap;
}

.hot-card{
width:320px;
background:#fff;
border-radius:10px;
box-shadow:0 5px 15px rgba(0,0,0,0.2);
overflow:hidden;
}

.hot-card img{
width:100%;
height:200px;
object-fit:cover;
}

.hot-info{
padding:15px;
}

.price{
color:green;
font-size:20px;
font-weight:bold;
}

/* LISTING */

.listing{
padding:40px;
}

.property{
display:flex;
gap:20px;
flex-wrap:wrap;
justify-content:center;
}

.card{
width:250px;
background:white;
border-radius:10px;
overflow:hidden;
box-shadow:0 3px 10px rgba(0,0,0,0.2);
}

.card img{
width:100%;
height:160px;
object-fit:cover;
}

.info{
padding:10px;
}

</style>
</head>

<body>

<header>
<h1>🏠 Sesempurna Property</h1>
<p>Cari Rumah Impian Anda</p>
</header>

<!-- HOT ITEM -->

<section class="hot-section">

<h2 class="hot-title">🔥 Rumah Terbaik (Hot Item)</h2>

<div class="hot-container">

<div class="hot-card">
<img src="https://picsum.photos/400/200?house1">
<div class="hot-info">
<h3>Double Storey Shah Alam</h3>
<p class="price">RM650,000</p>
<p>4 Bilik • 3 Bilik Air</p>
</div>
</div>

<div class="hot-card">
<img src="https://picsum.photos/400/200?house2">
<div class="hot-info">
<h3>Condo Subang</h3>
<p class="price">RM420,000</p>
<p>3 Bilik • 2 Bilik Air</p>
</div>
</div>

<div class="hot-card">
<img src="https://picsum.photos/400/200?house3">
<div class="hot-info">
<h3>Bungalow Bangi</h3>
<p class="price">RM1,200,000</p>
<p>5 Bilik • 4 Bilik Air</p>
</div>
</div>

</div>

</section>

<!-- LISTING -->

<section class="listing">

<h2 style="text-align:center;">Semua Listing</h2>

<div class="property">

<div class="card">
<img src="https://picsum.photos/300/200?1">
<div class="info">
<h4>Rumah Teres Puchong</h4>
<p class="price">RM550,000</p>
</div>
</div>

<div class="card">
<img src="https://picsum.photos/300/200?2">
<div class="info">
<h4>Apartment Kajang</h4>
<p class="price">RM300,000</p>
</div>
</div>

</div>

</section>

</body>
</html>
